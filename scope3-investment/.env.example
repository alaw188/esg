# NVIDIA NIM / Integrate API keys  —  https://build.nvidia.com/
# The .env file is SECRET and must NEVER be committed to git.
# On your cloud host, set these as environment variables instead of uploading .env.
# (This .env.example is safe to commit — it contains no real keys.)

# Default model (Nemotron)
NVIDIA_API_KEY=your_nemotron_api_key_here

# Second/third model (Gemma + MiniMax share one key in this setup)
NVIDIA_API_KEY_GEMMA=your_gemma_or_shared_api_key_here

# Optional overrides
# NVIDIA_MODEL=nemotron          # default model key: nemotron | gemma | minimax
# PORT=8080                      # host usually supplies PORT; only set for local runs
